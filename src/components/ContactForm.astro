<div id="contact-wrapper">
  <!-- Formulario Principal -->
  <form
    id="contact-form"
    class="contact-form"
    data-form-id="3d9b6eefac0748c9b63abad2673194d6"
  >
    <div class="form-group">
      <label for="first_name">Nombre</label>
      <input type="text" name="name" placeholder="Nombre" required />
    </div>

    <div class="form-group">
      <label for="company_name">Nombre de la empresa</label>
      <input
        type="text"
        name="company"
        placeholder="Nombre de la empresa"
        required
      />
    </div>

    <div class="form-group">
      <label for="email">Correo</label>
      <input type="email" name="email" placeholder="Correo" required />
    </div>

    <div class="form-group">
      <label for="phone">Teléfono</label>
      <input type="tel" name="phone" placeholder="Teléfono" required />
    </div>
    <div class="form-group">
      <label for="servicio">Servicio requerido</label>
      <select name="servicio" required>
        <option value="">Seleccionar servicio</option>
        <option value="Depósito Fiscal">Depósito Fiscal</option>
        <option value="Almacén General">Almacén General</option>
        <option value="Cross Dock">Cross Dock</option>
        <option value="Fulfillment">Fulfillment</option>
        <option value="Distribución">Distribución</option>
      </select>
    </div>

    <div class="form-group">
      <label for="message">Mensaje</label>
      <textarea name="message" placeholder="Mensaje" required rows="4"
      ></textarea>
    </div>

    <input
      type="text"
      name="_website"
      tabindex="-1"
      autocomplete="off"
      style="display:none"
      value=""
    />
    <input type="hidden" name="site" value="genca" />

    <p
      id="error-message"
      style="display:none; color: red; font-size: 14px; margin-bottom: 8px;"
    >
    </p>

    <div class="form-actions">
      <button type="submit" id="submit-btn" class="btn-submit">
        <span class="btn-text">Enviar</span>
        <span class="btn-loader" style="display: none;">Enviando...</span>
        <i class="fas fa-angle-right"></i>
      </button>
    </div>
  </form>

  <!-- Mensaje de Éxito (Oculto por defecto) -->
  <div id="success-message" class="success-block" style="display: none;">
    <div class="success-content">
      <div class="success-icon">✓</div>
      <h3>¡Gracias por contactarnos!</h3>
      <p>
        Tu mensaje ha sido enviado con éxito. Un especialista de nuestro equipo
        se pondrá en contacto contigo a la brevedad.
      </p>
    </div>
  </div>
</div>

<script is:inline>
  console.log("v2");

  const form = document.getElementById("contact-form");
  const successMsg = document.getElementById("success-message");
  const submitBtn = document.getElementById("submit-btn");
  const btnText = submitBtn.querySelector(".btn-text");
  const btnLoader = submitBtn.querySelector(".btn-loader");
  const errorMessage = document.getElementById("error-message");

  const ERROR_MESSAGES = {
    validation_failed:
      "Algunos campos no son válidos. Por favor, revisá el formulario.",
    rate_limited_ip_minute:
      "Demasiados intentos. Esperá un momento y volvé a intentarlo.",
    rate_limited_ip_hour:
      "Demasiados intentos. Esperá un momento y volvé a intentarlo.",
    rate_limited_form_day:
      "Se alcanzó el límite de envíos por hoy. Intentá mañana.",
    form_not_found:
      "Error de configuración del formulario. Contactanos directamente.",
    payload_too_large: "El mensaje es demasiado largo. Por favor, resumilo.",
  };

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    btnText.style.display = "none";
    btnLoader.style.display = "inline";
    errorMessage.style.display = "none";

    const formId = form.dataset.formId || "";

    const payload = {
      name: form.elements.namedItem("name").value,
      company: form.elements.namedItem("company").value,
      email: form.elements.namedItem("email").value,
      phone: form.elements.namedItem("phone").value,
      servicio: form.elements.namedItem("servicio").value,
      message: form.elements.namedItem("message").value,
      site: "genca",
    };

    // Merge UTM data from localStorage
    try {
      const utmRaw = localStorage.getItem("__utm_data");
      if (utmRaw) Object.assign(payload, JSON.parse(utmRaw));
    } catch (_) {}

    console.log("[ContactForm] Enviando formulario...");

    fetch("https://hook.us2.make.com/vzhcg5ny8z7x51emokpa735pgu52b4hd", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    })
      .then(() => console.log("[ContactForm] Make OK"))
      .catch((err) => console.error("[ContactForm] Make FAIL", err));

    try {
      const res = await fetch(
        `https://mb-suite.com/api/v1/public/forms/submit?formId=${formId}`,
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            formId,
            ...payload,
            _website: form.elements.namedItem("_website").value,
          }),
        },
      );

      const data = await res.json();

      if (data.success === true) {
        console.log("[ContactForm] mb-suite OK", data);
        form.style.display = "none";
        successMsg.style.display = "block";
        form.reset();

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: "form_submit", form_id: formId });
      } else {
        console.warn("[ContactForm] mb-suite FAIL", data);
        const msg =
          ERROR_MESSAGES[data.error] ||
          "Hubo un error al enviar el formulario. Por favor, intente nuevamente.";
        errorMessage.textContent = msg;
        errorMessage.style.display = "block";
        submitBtn.disabled = false;
        btnText.style.display = "inline";
        btnLoader.style.display = "none";
      }
    } catch (err) {
      console.error("[ContactForm] mb-suite EXCEPTION", err);
      errorMessage.textContent =
        "Hubo un error al enviar el formulario. Por favor, intente nuevamente.";
      errorMessage.style.display = "block";
      submitBtn.disabled = false;
      btnText.style.display = "inline";
      btnLoader.style.display = "none";
    }
  });
</script>

