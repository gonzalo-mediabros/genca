---
const baseUrl = import.meta.env.BASE_URL;
---

<header class="main-header">
  <div class="container header-container">
    <div class="logo">
      <a href={`${baseUrl}`}>
        <img
          src={baseUrl + "logo-blanco.png"}
          alt="Genca Logo"
          width="267"
          height="auto"
        />
      </a>
    </div>

    <!-- Navegación Escritorio -->
    <nav class="nav-links desktop-only">
      <ul>
        <li><a href={`${baseUrl}#inicio`}>INICIO</a></li>
        <li><a href={`${baseUrl}#servicios`}>SERVICIOS</a></li>
        <li><a href={`${baseUrl}#nosotros`}>NOSOTROS</a></li>
        <li>
          <a href={`${baseUrl}#contacto`} class="contact-link">CONTACTO</a>
        </li>
      </ul>
    </nav>

    <!-- Botón Burger (Mobile) -->
    <button class="mobile-menu-btn" id="burger-btn" aria-label="Abrir Menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Menú Lateral (Drawer) -->
  <div class="mobile-drawer" id="mobile-drawer">
    <div class="drawer-header">
      <button class="close-btn" id="close-btn" aria-label="Cerrar Menú"
        >&times;</button
      >
    </div>
    <nav class="mobile-nav">
      <ul>
        <li><a href={`${baseUrl}#inicio`}>INICIO</a></li>
        <li><a href={`${baseUrl}#servicios`}>SERVICIOS</a></li>
        <li><a href={`${baseUrl}#nosotros`}>NOSOTROS</a></li>
        <li><a href={`${baseUrl}#contacto`}>CONTACTO</a></li>
      </ul>
    </nav>
  </div>

  <!-- Overlay -->
  <div class="drawer-overlay" id="drawer-overlay"></div>
</header>

<script is:inline>
  const burgerBtn = document.getElementById("burger-btn");
  const closeBtn = document.getElementById("close-btn");
  const drawer = document.getElementById("mobile-drawer");
  const overlay = document.getElementById("drawer-overlay");
  const mobileLinks = document.querySelectorAll(".mobile-nav a");

  function toggleMenu() {
    drawer.classList.toggle("is-open");
    overlay.classList.toggle("is-visible");
    document.body.classList.toggle("no-scroll");
  }

  burgerBtn?.addEventListener("click", toggleMenu);
  closeBtn?.addEventListener("click", toggleMenu);
  overlay?.addEventListener("click", toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      drawer.classList.remove("is-open");
      overlay.classList.remove("is-visible");
      document.body.classList.remove("no-scroll");
    });
  });
</script>

<style>
  .main-header {
    background-color: var(--dark-blue);
    color: var(--white);
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 99999;

    display: flex;
    align-items: center;
    transition: all 0.3s ease;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo img {
    display: block;
    width: 267px;
  }

  /* Desktop Nav */
  .nav-links ul {
    display: flex;
    gap: 40px;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-oswald);
    font-size: 20px;
    font-weight: 400;
    color: var(--white);
    letter-spacing: 0.05em;
  }

  .nav-links a:hover {
    color: var(--orange);
    text-decoration: underline;
    text-underline-offset: 10px;
    text-decoration-thickness: 3px;
  }

  /* Mobile Burger */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 7px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    z-index: 100;
  }

  .mobile-menu-btn span {
    display: block;
    width: 28px;
    height: 2px; /* Más fino y elegante */
    background-color: var(--white);
    transition: all 0.3s ease;
  }

  /* Mobile Drawer */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: -100%; /* Oculto a la derecha */
    width: 300px;
    height: 100vh;
    background-color: var(--dark-blue);
    z-index: 100000;
    transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 30px;
    display: flex;
    flex-direction: column;
    box-shadow: -10px 0 30px rgba(0, 0, 0, 0.2);
  }

  .mobile-drawer.is-open {
    right: 0;
  }

  .drawer-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 50px;
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--white);
    font-size: 40px;
    cursor: pointer;
    line-height: 1;
  }

  .mobile-nav ul {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .mobile-nav a {
    font-family: var(--font-oswald);
    font-size: 24px;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
  }

  /* Overlay */
  .drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 99999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .drawer-overlay.is-visible {
    opacity: 1;
    visibility: visible;
  }

  @media (max-width: 992px) {
    .main-header {
      /* height: 80px; */
    }

    .logo img {
      width: 180px;
    }

    .desktop-only {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }

  :global(.no-scroll) {
    overflow: hidden !important;
  }
</style>
